# Supabase project URL — Project settings → API → Project URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon (public) key — Project settings → API → anon/public
# Safe to ship in the client bundle; RLS is what gates data access.
VITE_SUPABASE_ANON_KEY=your-anon-key

# The single Google account allowed to sign into this deployment is stored
# in Postgres (public.app_settings.allowed_email) — the client reads it via
# the allowed_email() RPC. Set it once, post-migration:
#   update public.app_settings set allowed_email = 'you@example.com';

# --- Worker secrets ---------------------------------------------------------
# These are NOT used by the Vite dev server; set them on the Worker via:
#   wrangler secret put ALLOWED_EMAIL
#   wrangler secret put SUPABASE_URL
#   wrangler secret put SUPABASE_ANON_KEY
# Listed here for documentation only.
ALLOWED_EMAIL=you@example.com
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
