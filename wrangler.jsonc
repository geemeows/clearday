{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "clearday",
  "main": "src/worker/index.ts",
  "compatibility_date": "2025-09-02",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "vars": {
    "ALLOWED_EMAIL": "",
    "SUPABASE_URL": "",
    "SUPABASE_ANON_KEY": ""
  }
}
