{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "clearday",
  "main": "src/worker/index.ts",
  "compatibility_date": "2025-09-02",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/oauth/*", "/api/*"]
  },
  "vars": {
    "AUTH_PROXY_URL": "https://auth.clearday.geemeows.com"
  },
  "triggers": {
    // Provider-sync cron: every minute the orchestrator polls each
    // connected provider (github, google calendar, slack) and upserts new
    // Signals. The Slack history window (`historyWindowSec`, default 120s)
    // intentionally overlaps the cron interval — idempotent upsert dedupes.
    "crons": ["*/1 * * * *"]
  }
  // Secrets (set via `wrangler secret put`):
  //   STATE_HMAC_SECRET, SUPABASE_SERVICE_ROLE_KEY,
  //   GITHUB_CLIENT_ID, GITHUB_CLIENT_SECRET,
  //   GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET,
  //   SLACK_CLIENT_ID, SLACK_CLIENT_SECRET, SLACK_SIGNING_SECRET,
  //   AI_KEY_SECRET (envelope-encryption key for stored LLM API keys),
  //   VAPID_PUBLIC_KEY, VAPID_PRIVATE_KEY, VAPID_SUBJECT (Web Push)
}
